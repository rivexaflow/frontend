# ────────────────────────────────────────────────────────────────────────
# Rivexaflow — environment configuration template
# Copy this file to `.env` (or `.env.local`) and adjust per environment.
# ────────────────────────────────────────────────────────────────────────
# Anything prefixed with NEXT_PUBLIC_ is bundled into the client build, so
# do NOT put secrets here.
#
# Production (Rivexa SaaS Platform API):
#   NEXT_PUBLIC_API_BASE_URL=https://rivexaflow.in/api
#   NEXT_PUBLIC_SOCKET_URL=https://rivexaflow.in
#
# Local backend (when running the API yourself):
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
#   NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

NEXT_PUBLIC_API_BASE_URL=https://rivexaflow.in/api
NEXT_PUBLIC_SOCKET_URL=https://rivexaflow.in
